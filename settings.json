{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); dir=$(basename \"$cwd\"); tokens=$(echo \"$input\" | jq -r '.context.tokens_loaded // 0'); exceeds=$(echo \"$input\" | jq -r '.context.exceeds_200k_tokens // false'); if [ -d \"$cwd/.git\" ]; then branch=$(cd \"$cwd\" && git -c core.useBuiltinFSMonitor=false branch --show-current 2>/dev/null); git_info=\" on ${branch:-unknown}\"; else git_info=\"\"; fi; if [ \"$tokens\" != \"0\" ] && [ \"$tokens\" != \"null\" ]; then tokens_k=$((tokens / 1000)); if [ \"$exceeds\" = \"true\" ]; then context_info=\" | ${tokens_k}k tokens (!)\"; else context_info=\" | ${tokens_k}k tokens\"; fi; else context_info=\"\"; fi; printf \"${dir}${git_info} | ${model}${context_info}\""
  },
  "enabledPlugins": {
    "feature-dev@claude-code-plugins": true,
    "research-academic@skills": true,
    "lang-r@skills": true,
    "lang-julia@skills": true,
    "lang-stan@skills": true,
    "dev-workflow@skills": true,
    "github-ops@skills": true,
    "org-management@skills": true,
    "bot-automation@skills": true,
    "productivity@skills": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voiceEnabled": true,
  "permissions": {
    "allow": [
      "Agent",
      "WebSearch",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:www.bbc.co.uk)",
      "WebFetch(domain:www.theguardian.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:codecov.io)",
      "WebFetch(domain:www.r-pkg.org)",
      "WebFetch(domain:img.shields.io)",
      "WebFetch(domain:cranlogs.r-pkg.org)",
      "WebFetch(domain:doi.org)",
      "WebFetch(domain:dx.doi.org)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:www.medrxiv.org)",
      "WebFetch(domain:www.biorxiv.org)",
      "WebFetch(domain:pubmed.ncbi.nlm.nih.gov)",
      "WebFetch(domain:scholar.google.com)",
      "WebFetch(domain:cran.r-project.org)",
      "WebFetch(domain:r-lib.org)",
      "WebFetch(domain:ropensci.org)",
      "WebFetch(domain:docs.julialang.org)",
      "WebFetch(domain:juliapackages.com)",
      "WebFetch(domain:juliahub.com)",
      "WebFetch(domain:en.wikipedia.org)",
      "WebFetch(domain:epinowcast.org)",
      "WebFetch(domain:elifesciences.org)",
      "WebFetch(domain:julialang.org)",
      "WebFetch(domain:pkgdocs.julialang.org)",
      "WebFetch(domain:sciml.ai)",
      "WebFetch(domain:turinglang.org)",
      "WebFetch(domain:mc-stan.org)",
      "WebFetch(domain:posit.co)",
      "WebFetch(domain:rdrr.io)",
      "WebFetch(domain:taskfile.dev)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:neovim.io)",
      "WebFetch(domain:joss.theoj.org)",
      "WebFetch(domain:journals.plos.org)",
      "WebFetch(domain:www.nature.com)",
      "WebFetch(domain:www.thelancet.com)",
      "WebFetch(domain:www.bmj.com)",
      "WebFetch(domain:academic.oup.com)",
      "WebFetch(domain:www.sciencedirect.com)",
      "WebFetch(domain:www.lazyvim.org)",
      "mcp__github__get_me",
      "mcp__github__search_issues",
      "mcp__github__get_pull_request_status",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(awk:*)",
      "Bash(tr:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(env:*)",
      "Bash(stat:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(find:*)",
      "Bash(diff:*)",
      "Bash(chmod:*)",
