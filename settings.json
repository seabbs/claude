  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'if (.tool_input.command | test(\"^gh pr create\\\\b\")) then (if (.tool_input.command | test(\"# checks-passed\")) then empty else \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PreToolUse\\\",\\\"permissionDecision\\\":\\\"deny\\\",\\\"permissionDecisionReason\\\":\\\"Pre-PR checks required. Spawn a subagent via the Agent tool running the pre-pr-checks skill. When it reports ready, retry this command with a trailing # checks-passed comment.\\\"}}\" end) else empty end'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'if (.tool_input.command | test(\"^git commit\\\\b\")) then \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PreToolUse\\\",\\\"permissionDecision\\\":\\\"allow\\\",\\\"additionalContext\\\":\\\"PRE-COMMIT: If you have not run tests and formatters recently, do so now before committing (task test, task lint, task format, or project equivalents). Keep commits regular but keep tests green. If the project has no tests or formatters, skip silently.\\\"}}\" else empty end'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/code/seabbs/dotfiles/scripts/agent-session-track.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'if (.tool_input.command | test(\"^gh pr create\\\\b\")) then \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PostToolUse\\\",\\\"additionalContext\\\":\\\"Run /mark-pr-agent to tag this PR as agent-authored. Then spawn a background subagent via the Agent tool with run_in_background: true and tell it to run the pr-automate skill for this PR.\\\"}}\" elif (.tool_input.command | test(\"^git push\\\\b\")) then \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PostToolUse\\\",\\\"additionalContext\\\":\\\"Spawn a background subagent via the Agent tool with run_in_background: true and tell it to run the pr-automate skill for the open PR on this branch.\\\"}}\" else empty end'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/code/seabbs/dotfiles/scripts/agent-session-track.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/code/seabbs/dotfiles/scripts/agent-session-track.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/code/seabbs/dotfiles/scripts/agent-session-track.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/code/seabbs/dotfiles/scripts/agent-session-track.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/code/seabbs/dotfiles/scripts/agent-session-track.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/code/seabbs/dotfiles/scripts/agent-session-track.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); dir=$(basename \"$cwd\"); tokens=$(echo \"$input\" | jq -r '.context.tokens_loaded // 0'); exceeds=$(echo \"$input\" | jq -r '.context.exceeds_200k_tokens // false'); if [ -d \"$cwd/.git\" ]; then branch=$(cd \"$cwd\" && git -c core.useBuiltinFSMonitor=false branch --show-current 2>/dev/null); git_info=\" on ${branch:-unknown}\"; else git_info=\"\"; fi; if [ \"$tokens\" != \"0\" ] && [ \"$tokens\" != \"null\" ]; then tokens_k=$((tokens / 1000)); if [ \"$exceeds\" = \"true\" ]; then context_info=\" | ${tokens_k}k tokens (!)\"; else context_info=\" | ${tokens_k}k tokens\"; fi; else context_info=\"\"; fi; printf \"${dir}${git_info} | ${model}${context_info}\""
  },
  "enabledPlugins": {
    "feature-dev@claude-code-plugins": true,
    "research-academic@skills": true,
    "lang-r@skills": true,
    "lang-julia@skills": true,
    "lang-stan@skills": true,
    "dev-workflow@skills": true,
    "github-ops@skills": true,
    "org-management@skills": true,
    "bot-automation@skills": true,
    "productivity@skills": true
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "reasoningEffort": "auto",
  "effortLevel": "high"
}
