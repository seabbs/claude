      "Bash(gh repo create:*)",
      "Bash(gh repo list:*)",
      "Bash(gh repo sync:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run download:*)",
      "Bash(gh run list:*)",
      "Bash(gh run rerun:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(launchctl load:*)",
      "Bash(launchctl list:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'if (.tool_input.command | test(\"gh pr create\")) then (if (.tool_input.command | test(\"# checks-passed\")) then empty else \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PreToolUse\\\",\\\"permissionDecision\\\":\\\"deny\\\",\\\"permissionDecisionReason\\\":\\\"Before creating a PR, run full package checks via Taskfile or project equivalents: task format, task lint, task test, and task check (if available). Fix all issues. Once everything passes, retry with a trailing # checks-passed comment. If the project has no tests or formatters, skip straight to retrying with # checks-passed.\\\"}}\" end) else empty end'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'if (.tool_input.command | test(\"git commit\")) then \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PreToolUse\\\",\\\"permissionDecision\\\":\\\"allow\\\",\\\"additionalContext\\\":\\\"PRE-COMMIT: If you have not run tests and formatters recently, do so now before committing (task test, task lint, task format, or project equivalents). Keep commits regular but keep tests green. If the project has no tests or formatters, skip silently.\\\"}}\" else empty end'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'if (.tool_input.command | test(\"git push|gh pr create\")) then \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PostToolUse\\\",\\\"additionalContext\\\":\\\"Launch a background agent (run_in_background: true) to monitor CI. The agent should run gh pr checks every 3 minutes for up to 30 minutes. If a check fails, report back. Do NOT block the main conversation.\\\"}}\" else empty end'"
          }
        ]
      }
    ]
  }
}
